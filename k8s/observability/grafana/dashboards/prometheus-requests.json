{
  "uid": "agentgw-prometheus",
  "title": "Agentgateway — LLM usage (Prometheus)",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total requests by team",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (org) (agentgateway_requests_total)",
          "legendFormat": "{{org}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total tokens by team",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (org) (agentgateway_gen_ai_client_token_usage_sum)",
          "legendFormat": "{{org}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request rate by team (org)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (org) (rate(agentgateway_requests_total[1m]))",
          "legendFormat": "{{org}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Token usage rate by team (org)",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (org) (rate(agentgateway_gen_ai_client_token_usage_sum[1m]))",
          "legendFormat": "{{org}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Token usage rate by model (gen_ai_request_model)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (gen_ai_request_model, gen_ai_token_type) (rate(agentgateway_gen_ai_client_token_usage_sum[1m]))",
          "legendFormat": "{{gen_ai_request_model}} ({{gen_ai_token_type}})"
        }
      ]
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "__comment": "Metric names verified against agentgateway v1.2.1 /metrics. The org label is added by the metrics-labels AgentgatewayPolicy. Stat panels show cumulative totals (non-zero even when idle); timeseries show live rates during traffic."
}
