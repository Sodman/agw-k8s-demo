# Copy this file to `.env` and fill in your real keys, then `source .env`.
#   cp .env.example .env && $EDITOR .env && source .env
#
# These keys are used by scripts/create-secrets.sh to create Kubernetes Secrets.
# They are NEVER written into any committed manifest. `.env` is gitignored.

# Required for the OpenAI route (models matching gpt-*).
export OPENAI_API_KEY="sk-..."

# Required for the Anthropic route (models matching claude-*).
# Get one at https://console.anthropic.com/ . If you leave this unset, the
# OpenAI route still works; claude-* requests will get an auth error from Anthropic.
export ANTHROPIC_API_KEY="sk-ant-..."

# Optional — only needed if you apply k8s/agentgateway/extras/fireworks.yaml
# (models matching accounts/fireworks/*).
export FIREWORKS_API_KEY=""
